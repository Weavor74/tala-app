{
  "name": "tala-app",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"npm run dev:vite\" \"npm run dev:electron\" \"npm run dev:inference\"",
    "dev:vite": "vite",
    "dev:electron": "tsc -p electron && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:inference": ".\\scripts\\diagnostics\\launch-inference.bat",
    "build": "tsc -b && tsc -p electron && vite build",
    "dist": "npm run build && electron-builder",
    "dist:universal": "scripts\\diagnostics\\make_universal.bat",
    "package:smoke": "npx tsx scripts/diagnostics/run-release-packaging-smoke.ts",
    "artifacts:validate": "npx tsx scripts/diagnostics/validate-release-artifacts.ts",
    "release:check": "npm run build && npm run test && npm run test:phase-c && npm run package:smoke && npm run artifacts:validate",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:phase-c": "vitest run tests/StartupResilienceIntegration.test.ts tests/ToolExecutionRuntimeLoop.integration.test.ts tests/MemoryAuthorityStrictEnforcement.test.ts tests/InferenceProviderFallback.integration.test.ts tests/autonomy/AutonomyCycleIntegration.test.ts",
    "test:phase-c:watch": "vitest tests/StartupResilienceIntegration.test.ts tests/ToolExecutionRuntimeLoop.integration.test.ts tests/MemoryAuthorityStrictEnforcement.test.ts tests/InferenceProviderFallback.integration.test.ts tests/autonomy/AutonomyCycleIntegration.test.ts",
    "preview": "vite preview",
    "postinstall": "patch-package",
    "repo:check": "npx tsx scripts/diagnostics/validate_repo_structure.ts",
    "repo:boundaries": "npx tsx scripts/diagnostics/validate_subsystem_boundaries.ts",
    "repo:fullcheck": "npm run repo:check && npm run repo:boundaries && npm run docs:validate && npm run lint && npm run build && npm run test",
    "docs:index": "npx tsx scripts/docs/index_repo_docs.ts",
    "docs:architecture": "npx tsx scripts/docs/extract_architecture.ts",
    "docs:contracts": "npx tsx scripts/docs/generate_contract_docs.ts",
    "docs:regen": "npm run docs:index && npm run docs:architecture && npm run docs:contracts",
    "docs:verify": "npx tsx scripts/diagnostics/validate_docs_drift.ts",
    "docs:validate:naming": "npx tsx tools/doclock/validate-naming-contract.ts",
    "docs:gatekeeper:naming": "npx tsx tools/doclock/validate-naming-contract.ts --gatekeeper",
    "docs:baseline:naming": "npx tsx tools/doclock/validate-naming-contract.ts --update-baseline",
    "docs:classify:artifact": "npx tsx tools/doclock/classify-artifact.ts",
    "docs:validate:artifact-name": "npx tsx tools/doclock/validate-artifact-name.ts",
    "docs:suggest:artifact-name": "npx tsx tools/doclock/suggest-name.ts",
    "docs:scan-impact": "npx tsx tools/doclock/scan-impact.ts",
    "docs:heal": "npx tsx tools/doclock/heal-docs.ts",
    "docs:validate:doclock": "npx tsx tools/doclock/validate-docs.ts",
    "docs:validate": "npm run docs:verify && npm run docs:validate:naming && npm run docs:validate:doclock",
    "docs:heal-and-validate": "npm run docs:heal && npm run docs:validate",
    "docs:selfheal": "npm run docs:regen && npm run docs:heal-and-validate",
    "code:check": "npm run repo:boundaries",
    "code:heal": "npx tsx scripts/diagnostics/maintenance/code_maintenance.ts",
    "memory:check": "npx tsx scripts/diagnostics/maintenance/memory_maintenance.ts --mode=audit",
    "memory:heal": "npx tsx scripts/diagnostics/maintenance/memory_maintenance.ts --mode=apply-safe",
    "memory:purge": "npx tsx scripts/maintenance/purge_memory_state.ts",
    "memory:purge:dry": "npx tsx scripts/maintenance/purge_memory_state.ts --dry-run",
    "memory:purge:verify": "npx tsx scripts/maintenance/verify_memory_purge_state.ts",
    "memory:up": "node scripts/memory-cmd.js up",
    "memory:down": "node scripts/memory-cmd.js down",
    "memory:logs": "node scripts/memory-cmd.js logs",
    "memory:reset": "node scripts/memory-cmd.js down --reset && node scripts/memory-cmd.js up",
    "memory:import:autobio-canon": "npx tsx scripts/migrations/oneTimeAutobioCanonImport.ts",
    "memory:ltmf:enrich": "npx tsx scripts/maintenance/enrich_memory_frontmatter.ts",
    "dev:with-memory": "npm run memory:up && npm run dev",
    "self:maintain": "npx tsx scripts/diagnostics/run_self_maintenance.ts",
    "self:watch": "npx tsx scripts/diagnostics/watch_self_maintenance.ts",
    "setup:verify": "bash scripts/verify-setup.sh",
    "setup:venvs": "bash scripts/setup-mcp-venvs.sh"
  },
  "build": {
    "appId": "com.antigravity.tala",
    "productName": "Tala",
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "bin/python-win",
        "to": "bin/python-win",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "bin/python",
        "to": "bin/python",
        "filter": [
          "**/*"
        ]
      },
      "models",
      "memory",
      {
        "from": "mcp-servers",
        "to": "mcp-servers",
        "filter": [
          "**/*",
          "!**/venv/**",
          "!**/__pycache__/**",
          "!**/.git/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "local-inference",
        "to": "local-inference",
        "filter": [
          "**/*",
          "!**/venv/**",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      },
      {
        "from": "runtime/guardrails",
        "to": "runtime/guardrails",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "scripts/diagnostics/launch-inference.bat",
        "to": "launch-inference.bat"
      },
      {
        "from": "scripts/diagnostics/launch-inference.sh",
        "to": "launch-inference.sh"
      },
      {
        "from": "docs/build/offline_portable_build.md",
        "to": "PORTABLE_BUILD_README.md"
      }
    ],
    "win": {
      "target": [
        "dir"
      ]
    },
    "mac": {
      "target": [
        "dir"
      ]
    },
    "linux": {
      "target": [
        "dir"
      ]
    },
    "asar": false
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.988.0",
    "@aws-sdk/lib-storage": "^3.988.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "chokidar": "^3.6.0",
    "discord.js": "^14.25.1",
    "electron-squirrel-startup": "^1.0.1",
    "imapflow": "^1.2.9",
    "node-pty": "^1.1.0",
    "nodemailer": "^8.0.1",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "reactflow": "^11.11.4",
    "sanitize-html": "^2.17.2",
    "screenshot-desktop": "^1.15.3",
    "undici": "^7.22.0",
    "uuid": "^11.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.3"
  }
}
