{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "RiskAssessment",
    "type": "object",
    "required": [
        "proposalId",
        "finalScore",
        "gates"
    ],
    "properties": {
        "proposalId": {
            "type": "string"
        },
        "finalScore": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
        },
        "gates": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "name",
                    "passed"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "passed": {
                        "type": "boolean"
                    },
                    "details": {
                        "type": "string"
                    }
                }
            }
        },
        "approvalRequired": {
            "type": "boolean"
        },
        "canAutoApply": {
            "type": "boolean"
        }
    }
}