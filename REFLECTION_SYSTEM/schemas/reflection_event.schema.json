{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ReflectionEvent",
    "type": "object",
    "required": [
        "id",
        "timestamp",
        "summary"
    ],
    "properties": {
        "id": {
            "type": "string",
            "description": "Unique UUID for the reflection event."
        },
        "timestamp": {
            "type": "string",
            "format": "date-time"
        },
        "summary": {
            "type": "string",
            "description": "High-level summary of the analysis."
        },
        "evidence": {
            "type": "object",
            "properties": {
                "turns": {
                    "type": "array",
                    "items": {
                        "type": "object"
                    }
                },
                "errors": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "failedToolCalls": {
                    "type": "array",
                    "items": {
                        "type": "object"
                    }
                }
            }
        },
        "observations": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "metrics": {
            "type": "object",
            "properties": {
                "averageLatencyMs": {
                    "type": "number"
                },
                "errorRate": {
                    "type": "number"
                }
            }
        }
    }
}